# Copia este ficheiro para ".env" e preenche com o teu token real.
# Cria o token em: https://dash.cloudflare.com/profile/api-tokens
# Template a usar: "Radar" (scope de leitura, não precisa de acesso a nenhuma zona)
CLOUDFLARE_API_TOKEN=chave_api_aqui_

# Código de país ISO alpha-2 usado por omissão em todos os widgets
DEFAULT_LOCATION=PT

# Tempo (segundos) que cada resposta da Radar API fica em cache local
CACHE_TTL_SECONDS=60

# Origens permitidas a chamar esta API (frontend em dev)
CORS_ORIGINS=http://localhost:5173
